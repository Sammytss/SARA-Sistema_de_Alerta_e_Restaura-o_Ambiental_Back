# ── Banco de dados ────────────────────────────────────────────────
# Em dev com docker-compose, use o serviço "db" como host.
DATABASE_URL=ex://ex:ex@db:ex/ex

# ── JWT ───────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALG=ex
ACCESS_TTL_MIN=ex
REFRESH_TTL_DAYS=ex

# ── CORS ──────────────────────────────────────────────────────────
# Em dev: * (aceita qualquer origem)
# Em prod: lista separada por vírgula ex.: https://sara.to.gov.br
CORS_ORIGINS=*

# ── Upload de fotos ───────────────────────────────────────────────
UPLOAD_DIR=ex
MAX_FOTO_MB=ex

# ── Ambiente ─────────────────────────────────────────────────────
ENV=dev

# ── APIs externas (Fase 6) ────────────────────────────────────────
# As chaves abaixo NUNCA vão para o app Flutter.

# INPE / BDQueimadas (sem autenticação para maioria dos endpoints)
INPE_BASE_URL=ex
# CIGMA-TO (solicitar credenciais ao NATURATINS)
CIGMA_BASE_URL=
CIGMA_TOKEN=

# MapBiomas Alerta (cadastro em plataforma.alerta.mapbiomas.org)
MAPBIOMAS_ALERTA_URL=ex
MAPBIOMAS_EMAIL=
MAPBIOMAS_SENHA=
